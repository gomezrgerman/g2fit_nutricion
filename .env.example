# --- ANTHROPIC ---
ANTHROPIC_API_KEY=sk-ant-api03-...REEMPLAZAR
# Modelo a usar (recomendado: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=16000
CLAUDE_TEMPERATURE=0.3
CLAUDE_TIMEOUT_MS=120000

# --- GMAIL ---
# Configurar credencial OAuth2 en n8n UI
# El correo desde el que se envían los emails
GMAIL_FROM_EMAIL=nutricion@g2fit.com
GMAIL_FROM_NAME=G2Fit Nutrición

# --- SLACK (para notificaciones a nutricionista) ---
SLACK_BOT_TOKEN=xoxb-...REEMPLAZAR
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_CHANNEL_REVISIONES=#revisiones-dietas

# --- TELEGRAM (alternativa a Slack) ---
TELEGRAM_BOT_TOKEN=1234567890:AAF...REEMPLAZAR
TELEGRAM_CHAT_ID=-100XXXXXXXXXX

# --- NOTION ---
NOTION_INTEGRATION_TOKEN=secret_...REEMPLAZAR
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_API_VERSION=2022-06-28

# --- NUTRICIONISTA ---
NUTRICIONISTA_NOMBRE=Nombre Nutricionista
NUTRICIONISTA_EMAIL=nutricionista@g2fit.com
NUTRICIONISTA_TELEFONO=+34 600 000 000
NUTRICIONISTA_NUM_COLEGIADO=CO-XXXXX
NUTRICIONISTA_TITULO=Dietista-Nutricionista

# --- WEBHOOKS n8n ---
N8N_BASE_URL=https://tu-n8n.dominio.com
WEBHOOK_NUEVA_SOLICITUD=/nueva-solicitud-dieta
WEBHOOK_APROBAR_DIETA=/aprobar-dieta

# --- SCRIPTS Y RUTAS ---
PDF_SCRIPT_PATH=/opt/scripts/generar_pdf_dieta.py
PDF_OUTPUT_DIR=/home/pdfs/
LOGO_PATH=/opt/assets/logo_g2fit.png

# --- STRIPE ---
# Secret key (sk_live_... en producción, sk_test_... en pruebas)
STRIPE_SECRET_KEY=sk_live_...REEMPLAZAR
# Signing secret del webhook endpoint configurado en Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...REEMPLAZAR
# Price ID del producto 9,99€/mes (crear en Stripe Dashboard > Products)
STRIPE_PRICE_ID=price_...REEMPLAZAR
# URL del Payment Link con prefilled_email (crear en Stripe Dashboard > Payment Links)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/...REEMPLAZAR

# --- CONFIGURACIÓN GENERAL ---
# Tolerancia para validación de macros (%)
MACRO_TOLERANCE_PERCENT=5
# Horas de timeout para aprobación manual
APPROVAL_TIMEOUT_HOURS=48
# Reintentos para operaciones DB
DB_MAX_RETRIES=3

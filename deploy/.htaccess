# G2Fit Nutricion — Hostinger Apache config

# Pagina por defecto
DirectoryIndex index.html

# Cabeceras de seguridad basicas
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache para assets estaticos (no aplica al HTML para que siempre este fresco)
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff2?)$">
  Header set Cache-Control "max-age=604800, public"
</FilesMatch>

<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Comprimir respuestas
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript
</IfModule>

# Errores personalizados (redirige 404 al index para SPA)
ErrorDocument 404 /index.html
